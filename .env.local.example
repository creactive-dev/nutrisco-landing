# ============================================================
# NUTRICO LANDING — Variables de entorno
# Copiar este archivo a .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# URL del plan de suscripción en Mercado Pago ($19.990/mes)
# Configurar en: mercadopago.cl > Tu negocio > Pagos > Suscripciones
NEXT_PUBLIC_MP_PAYMENT_URL=https://mpago.la/XXXXXXXXX

# Número WhatsApp Business de Constanza (con código país, sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=56912345678

# URL de producción de la landing (para metadata OG/SEO)
NEXT_PUBLIC_SITE_URL=https://nutrico.constanzanutricion.cl

# Meta Pixel ID (opcional — para tracking de conversiones)
# NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXX
